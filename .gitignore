

# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Precompiled Assets
 MR_project/SourceArt/**/*.png
 MR_project/SourceArt/**/*.tga

# Binary Files
 MR_project/Binaries/*
 MR_project/Plugins/**/Binaries/*

# Builds
 MR_project/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
! MR_project/Build/*/
 MR_project/Build/*/**
!MR_project/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!/MR_project/Build/**/*.ico

# MR_project/Built data for maps
* MR_project/_BuiltData.uasset

# Configuration files generated by the Editor
 MR_project/Saved/*

# Compiled source files for the engine to use
 MR_project/Intermediate/*
 MR_project/Plugins/**/Intermediate/*

# Cache files for the editor to use
 MR_project/DerivedDataCache/*

#-----------------------

# Precompiled Assets
 MRLabProject/SourceArt/**/*.png
 MRLabProject/SourceArt/**/*.tga

# Binary Files
 MRLabProject/Binaries/*
 MRLabProject/Plugins/**/Binaries/*

# Builds
MRLabProject/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
! MRLabProject/Build/*/
 MRLabProject/Build/*/**
!MRLabProject/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!MRLabProject/Build/**/*.ico

# MRLabProject/Built data for maps
* MRLabProject/_BuiltData.uasset

# Configuration files generated by the Editor
 MRLabProject/Saved/*

# Compiled source files for the engine to use
 MRLabProject/Intermediate/*
 MRLabProject/Plugins/**/Intermediate/*

# Cache files for the editor to use
 MRLabProject/DerivedDataCache/*



